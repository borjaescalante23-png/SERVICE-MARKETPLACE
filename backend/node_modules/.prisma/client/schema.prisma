generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  password        String
  firstName       String
  lastName        String
  phone           String?
  avatarUrl       String?
  role            String    @default("CLIENT")
  isActive        Boolean   @default(true)
  isProvider      Boolean   @default(false)
  isVerified      Boolean   @default(false)
  emailVerifiedAt DateTime?
  lastLoginAt     DateTime?
  theme           String    @default("light")
  language        String    @default("es")
  notifSettings   String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  professionalProfile ProfessionalProfile?
  clientBookings      Booking[]            @relation("ClientBookings")
  sentMessages        Message[]            @relation("SentMessages")
  reviews             Review[]             @relation("ClientReviews")
  flagEvents          FraudEvent[]
  refreshTokens       RefreshToken[]
  notifications       Notification[]
}

model ProfessionalProfile {
  id                 String    @id @default(uuid())
  userId             String    @unique
  user               User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  bio                String?
  verificationStatus String    @default("PENDING")
  verifiedAt         DateTime?
  rejectionReason    String?
  avgRating          Float     @default(0)
  totalReviews       Int       @default(0)
  acceptanceRate     Float     @default(0)
  cancellationRate   Float     @default(0)
  punctualityScore   Float     @default(0)
  completedJobs      Int       @default(0)
  isVisible          Boolean   @default(false)
  level              String    @default("VERIFIED")
  city               String?
  country            String?
  travelRadius       Int?      @default(25)
  serviceMode        String    @default("PRESENTIAL")
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt

  stripeConnectId     String?
  stripeConnectStatus String  @default("NOT_STARTED")
  kycStatus           String  @default("PENDING")
  selfieUrl           String?

  services          Service[]
  bookings          Booking[]              @relation("ProfessionalBookings")
  experienceEntries ExperienceEntry[]
  documents         VerificationDocument[]
  kycAttempts       KycAttempt[]
  availability      AvailabilitySlot[]
}

model ExperienceEntry {
  id              String              @id @default(uuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  title           String
  description     String
  serviceCategory String
  approximateDate String
  images          ExperienceImage[]
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt
}

model ExperienceImage {
  id           String          @id @default(uuid())
  experienceId String
  experience   ExperienceEntry @relation(fields: [experienceId], references: [id], onDelete: Cascade)
  fileUrl      String
  originalName String
  createdAt    DateTime        @default(now())
}

model VerificationDocument {
  id             String              @id @default(uuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  type           String
  fileUrl        String
  originalName   String
  status         String              @default("PENDING")
  reviewNote     String?
  aiAnalysis     String?
  reviewedAt     DateTime?
  createdAt      DateTime            @default(now())
}

model Service {
  id                 String              @id @default(uuid())
  professionalId     String
  professional       ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  name               String
  description        String
  category           String
  subcategory        String?
  price              Float
  duration           Int
  isActive           Boolean             @default(true)
  hasAssessmentVisit Boolean             @default(false)
  assessmentPrice    Float?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  bookings Booking[]
}

model Booking {
  id                    String              @id @default(uuid())
  clientId              String
  client                User                @relation("ClientBookings", fields: [clientId], references: [id])
  professionalId        String
  professional          ProfessionalProfile @relation("ProfessionalBookings", fields: [professionalId], references: [id])
  serviceId             String
  service               Service             @relation(fields: [serviceId], references: [id])
  status                String              @default("PENDING")
  paymentStatus         String              @default("PENDING")
  stripeSessionId       String?
  address               String
  scheduledAt           DateTime
  startedAt             DateTime?
  completedAt           DateTime?
  cancelledAt           DateTime?
  cancellationReason    String?
  cancelledBy           String?
  totalAmount           Float
  platformFee           Float
  professionalAmount    Float
  clientNotes           String?
  completedByProviderAt DateTime?
  autoReleaseAt         DateTime?
  verificationCode      String?
  providerEvidenceNote  String?
  isRecurring           Boolean             @default(false)
  recurringFrequency    String?
  recurringIntervalDays Int?
  recurringEndDate      DateTime?
  parentBookingId       String?
  createdAt             DateTime            @default(now())
  updatedAt             DateTime            @updatedAt

  escrow   EscrowTransaction?
  review   Review?
  messages Message[]
  dispute  Dispute?
}

model EscrowTransaction {
  id                 String    @id @default(uuid())
  bookingId          String    @unique
  booking            Booking   @relation(fields: [bookingId], references: [id])
  amount             Float
  status             String    @default("HELD")
  heldAt             DateTime  @default(now())
  releasedAt         DateTime?
  refundedAt         DateTime?
  refundAmount       Float?
  releaseScheduledAt DateTime?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
}

model Review {
  id                 String   @id @default(uuid())
  bookingId          String   @unique
  booking            Booking  @relation(fields: [bookingId], references: [id])
  clientId           String
  client             User     @relation("ClientReviews", fields: [clientId], references: [id])
  rating             Int
  comment            String
  isVerified         Boolean  @default(true)
  qualityScore       Int?
  punctualityScore   Int?
  communicationScore Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

model Message {
  id         String   @id @default(uuid())
  bookingId  String
  booking    Booking  @relation(fields: [bookingId], references: [id])
  senderId   String
  sender     User     @relation("SentMessages", fields: [senderId], references: [id])
  content    String
  isFlagged  Boolean  @default(false)
  flagReason String?
  isRead     Boolean  @default(false)
  createdAt  DateTime @default(now())
}

model Dispute {
  id          String             @id @default(uuid())
  bookingId   String             @unique
  booking     Booking            @relation(fields: [bookingId], references: [id])
  openedBy    String
  reason      String
  description String
  status      String             @default("OPEN")
  resolution  String?
  resolvedAt  DateTime?
  resolvedBy  String?
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  aiAnalysis  DisputeAIAnalysis?
}

model DisputeAIAnalysis {
  id            String    @id @default(uuid())
  disputeId     String    @unique
  dispute       Dispute   @relation(fields: [disputeId], references: [id])
  resolution    String
  confidence    Float
  reasoning     String
  partialAmount Float?
  executedAt    DateTime?
  createdAt     DateTime  @default(now())
}

model KycAttempt {
  id              String              @id @default(uuid())
  professionalId  String
  professional    ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  documentUrl     String
  selfieUrl       String
  result          String              @default("PROCESSING")
  aiAnalysis      String?
  faceMatchScore  Float?
  rejectionReason String?
  createdAt       DateTime            @default(now())
  reviewedAt      DateTime?
}

model FraudEvent {
  id          String   @id @default(uuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])
  eventType   String
  description String
  metadata    String?
  severity    String   @default("LOW")
  createdAt   DateTime @default(now())
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  token     String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())
}

model Notification {
  id        String   @id @default(uuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      String
  title     String
  body      String
  data      String?
  isRead    Boolean  @default(false)
  priority  String   @default("MEDIUM")
  createdAt DateTime @default(now())
}

model AvailabilitySlot {
  id             String              @id @default(uuid())
  professionalId String
  professional   ProfessionalProfile @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  dayOfWeek      Int
  startTime      String
  endTime        String
  isAvailable    Boolean             @default(true)
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  @@unique([professionalId, dayOfWeek])
}

model MatchScore {
  id             String   @id @default(uuid())
  professionalId String
  requestHash    String
  score          Float
  breakdown      String
  expiresAt      DateTime
  createdAt      DateTime @default(now())

  @@index([requestHash])
  @@index([professionalId])
}

model Opportunity {
  id          String    @id @default(uuid())
  userId      String
  type        String
  title       String
  description String
  metadata    String?
  isRead      Boolean   @default(false)
  expiresAt   DateTime?
  createdAt   DateTime  @default(now())

  @@index([userId])
}

model OpportunityRequest {
  id            String    @id @default(uuid())
  clientId      String
  category      String
  title         String
  description   String
  preferredDate DateTime?
  maxBudget     Float?
  address       String?
  status        String    @default("OPEN")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  applications OpportunityApplication[]

  @@index([clientId])
  @@index([status])
}

model OpportunityApplication {
  id             String             @id @default(uuid())
  requestId      String
  request        OpportunityRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  professionalId String
  proposedPrice  Float
  message        String
  status         String             @default("PENDING")
  createdAt      DateTime           @default(now())

  @@index([requestId])
  @@index([professionalId])
}
